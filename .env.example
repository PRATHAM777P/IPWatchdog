# IPWatchdog – Environment Variable Template
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# .env is already listed in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask ─────────────────────────────────────────────────────────────────────
# Generate a strong key:  python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Set to "true" only during local development
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1
FLASK_PORT=5000

# ── Upload limits ─────────────────────────────────────────────────────────────
MAX_UPLOAD_MB=50

# ── Real-time monitoring ──────────────────────────────────────────────────────
# Colon-separated list of filesystem paths the /monitor endpoint may tail.
# Leave empty to disable the live monitor feature entirely.
MONITOR_ALLOWED_PATHS=

# ── Threat Intelligence (all optional) ───────────────────────────────────────
# AbuseIPDB: https://www.abuseipdb.com/api
ABUSEIPDB_API_KEY=

# VirusTotal (reserved for future use): https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# GeoIP via ip-api.com (free, no key required; set false to disable)
GEOIP_ENABLED=true

# ── Detection tuning ──────────────────────────────────────────────────────────
KMEANS_CLUSTERS=10
ISOLATION_FOREST_CONTAMINATION=0.05
MIN_REQUESTS_THRESHOLD=3

# ── Email alerting (optional) ─────────────────────────────────────────────────
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_RECIPIENT=
